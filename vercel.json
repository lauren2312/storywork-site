{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/writing", "destination": "/writing/index.html" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "laurencshippy.com" }],
      "destination": "https://storywork.co/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.laurencshippy.com" }],
      "destination": "https://storywork.co/",
      "permanent": true
    },
    { "source": "/businessbuilder", "destination": "/businessbuilders", "permanent": true },
    { "source": "/business-builder", "destination": "/businessbuilders", "permanent": true },
    { "source": "/business-builders", "destination": "/businessbuilders", "permanent": true },
    { "source": "/strategyservices", "destination": "/businessbuilders", "permanent": true },
    { "source": "/strategy-services", "destination": "/businessbuilders", "permanent": true },
    { "source": "/themarketingengine", "destination": "/", "permanent": true },
    { "source": "/marketingengineliteworkshop", "destination": "/", "permanent": true },
    { "source": "/strategygamemastermind2021", "destination": "/", "permanent": true },
    { "source": "/team-1", "destination": "/#about", "permanent": true },
    { "source": "/copy-of-home", "destination": "/", "permanent": true },
    { "source": "/service-page/the-business-builder", "destination": "/businessbuilders", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/styles/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
