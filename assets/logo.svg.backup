<!-- StoryWork logo — closer outlined approximation
     Two outer overlapping squares (8-point star), inner concentric squares,
     SW serif italic monogram in deep teal.
     SWAP NOTE: replace with the real logo file when uploaded as a file
     attachment (paperclip button) — pasted images don't save to the project. -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120" role="img" aria-label="StoryWork logo">
  <g transform="translate(60 60)" fill="none" stroke-linejoin="miter" stroke-linecap="butt">
    <!-- Outer 8-point star: two overlapping squares, slightly different stroke widths -->
    <rect x="-46" y="-46" width="92" height="92" stroke="#a89373" stroke-width="2"/>
    <rect x="-46" y="-46" width="92" height="92" stroke="#a89373" stroke-width="2" transform="rotate(45)"/>
    <!-- Inner diamond -->
    <rect x="-26" y="-26" width="52" height="52" stroke="#a89373" stroke-width="1.6" transform="rotate(45)"/>
    <!-- Inner square -->
    <rect x="-19" y="-19" width="38" height="38" stroke="#a89373" stroke-width="1.4"/>
  </g>
  <!-- SW monogram -->
  <text x="60" y="68" text-anchor="middle"
        font-family="'Cormorant Garamond', Georgia, serif"
        font-size="26" font-weight="600" font-style="italic"
        fill="#0e4f56" letter-spacing="-0.5">SW</text>
</svg>
